{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gentle-ai.local/sdd-review-security/review-security-report.schema.json",
  "schemaName": "sdd-review-security.review-security-report.schema",
  "schemaVersion": 1,
  "title": "SDD Security Review Report JSON Contract",
  "description": "Canonical per-change review-security-report.json contract. review-security-report.md / sdd/{change-name}/review-security is a derived compatibility presentation generated from this JSON.",
  "$comment": "Evidence fields may cite paths, section anchors, sanitized summaries, unavailable-tooling statements, and redacted placeholders only. They must not include secrets, credentials, tokens, connection strings, PAN, PII, raw logs, sensitive payloads, production identifiers, full ID lists, generated bytes, or final-document-only values.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaName",
    "schemaVersion",
    "changeName",
    "artifactKind",
    "generatedAt",
    "status",
    "verdict",
    "nextRecommended",
    "sourceRefs",
    "catalogRefs",
    "generalReviewHandoff",
    "compactControlValidation",
    "sourceRowValidation",
    "blockers",
    "warnings",
    "unsafeEvidenceRejections",
    "warningCarryForward",
    "exceptions",
    "unavailableTooling",
    "artifactMetadata"
  ],
  "properties": {
    "schemaName": { "const": "sdd-review-security.review-security-report" },
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "changeName": { "type": "string", "minLength": 1 },
    "artifactKind": { "const": "canonical-security-review-report" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "status": { "enum": ["success", "blocked", "partial"] },
    "verdict": { "enum": ["PASS", "PASS WITH WARNINGS", "FAIL"] },
    "nextRecommended": { "enum": ["verify", "apply", "resolve-blockers"] },
    "sourceRefs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["secureDesign", "testDesign", "tasks", "applyProgress", "changedFiles"],
      "properties": {
        "secureDesign": { "$ref": "#/$defs/ref" },
        "testDesign": { "$ref": "#/$defs/ref" },
        "tasks": { "$ref": "#/$defs/ref" },
        "applyProgress": { "$ref": "#/$defs/ref" },
        "changedFiles": { "type": "array", "items": { "$ref": "#/$defs/ref" } }
      }
    },
    "catalogRefs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operationalJson", "humanMarkdown", "snapshotId", "expectedSourceRowCount", "expectedCompactControlCount"],
      "properties": {
        "operationalJson": { "const": "skills/sdd-review-security/references/security-guideline-catalog.operational.json" },
        "humanMarkdown": { "const": "skills/sdd-review-security/references/security-guideline-catalog.md" },
        "snapshotId": { "type": "string", "minLength": 1 },
        "expectedSourceRowCount": { "type": "integer", "const": 155 },
        "expectedCompactControlCount": { "type": "integer", "minimum": 1 }
      }
    },
    "generalReviewHandoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canonicalJsonRef", "derivedMarkdownRef", "verdict", "nonBlocking", "jsonAuthoritative", "markdownParityStatus", "handoffSummary", "securityRelevantRefs"],
      "properties": {
        "canonicalJsonRef": { "$ref": "#/$defs/ref" },
        "derivedMarkdownRef": { "$ref": "#/$defs/ref" },
        "verdict": { "enum": ["PASS", "PASS WITH WARNINGS", "FAIL"] },
        "nonBlocking": { "type": "boolean" },
        "jsonAuthoritative": { "const": true },
        "markdownParityStatus": { "enum": ["passed", "stale", "parity-failed", "not-present", "not-applicable"] },
        "handoffSummary": { "type": "string", "minLength": 1 },
        "securityRelevantRefs": { "type": "array", "items": { "$ref": "#/$defs/ref" } }
      }
    },
    "compactControlValidation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expectedCount", "validatedCount", "coverageStatus", "exactOnce", "rows"],
      "properties": {
        "expectedCount": { "type": "integer", "minimum": 1 },
        "validatedCount": { "type": "integer", "minimum": 0 },
        "coverageStatus": { "enum": ["complete", "incomplete"] },
        "exactOnce": { "type": "boolean" },
        "rows": { "type": "array", "items": { "$ref": "#/$defs/compactRow" } }
      }
    },
    "sourceRowValidation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["applies", "expectedCount", "validatedCount", "coverageStatus", "exactOnce", "reportMode", "fullMatrixRendered", "sectionCoverage", "focusedRows"],
      "properties": {
        "applies": { "type": "boolean" },
        "expectedCount": { "type": "integer", "const": 155 },
        "validatedCount": { "type": "integer", "minimum": 0, "maximum": 155 },
        "coverageStatus": { "enum": ["complete", "incomplete", "not-applicable"] },
        "exactOnce": { "type": "boolean" },
        "reportMode": { "enum": ["summary", "full-matrix"] },
        "fullMatrixRendered": { "type": "boolean" },
        "sectionCoverage": { "type": "array", "items": { "$ref": "#/$defs/sectionCoverage" } },
        "focusedRows": { "type": "array", "items": { "$ref": "#/$defs/sourceRow" } },
        "fullMatrixRows": { "type": "array", "items": { "$ref": "#/$defs/sourceRow" } }
      },
      "allOf": [
        {
          "if": { "properties": { "reportMode": { "const": "summary" } } },
          "then": { "properties": { "fullMatrixRendered": { "const": false } } }
        },
        {
          "if": { "properties": { "reportMode": { "const": "full-matrix" } } },
          "then": { "properties": { "fullMatrixRendered": { "const": true } }, "required": ["fullMatrixRows"] }
        }
      ]
    },
    "blockers": { "type": "array", "items": { "$ref": "#/$defs/finding" } },
    "warnings": { "type": "array", "items": { "$ref": "#/$defs/finding" } },
    "unsafeEvidenceRejections": { "type": "array", "items": { "$ref": "#/$defs/finding" } },
    "warningCarryForward": { "type": "array", "items": { "$ref": "#/$defs/finding" } },
    "exceptions": { "type": "array", "items": { "$ref": "#/$defs/exception" } },
    "unavailableTooling": { "type": "array", "items": { "type": "string" } },
    "artifactMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["canonicalJsonRef", "derivedMarkdownRef", "jsonPersisted", "jsonReadBack", "markdownGenerated", "markdownPersisted", "markdownReadBack", "parityStatus", "stateRegistration"],
      "properties": {
        "canonicalJsonRef": { "$ref": "#/$defs/ref" },
        "derivedMarkdownRef": { "$ref": "#/$defs/ref" },
        "jsonPersisted": { "type": "boolean" },
        "jsonReadBack": { "type": "boolean" },
        "markdownGenerated": { "type": "boolean" },
        "markdownPersisted": { "type": "boolean" },
        "markdownReadBack": { "type": "boolean" },
        "parityStatus": { "enum": ["passed", "stale", "parity-failed", "not-applicable"] },
        "stateRegistration": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/stateArtifactRef" }
        }
      }
    }
  },
  "$defs": {
    "ref": { "type": "string", "minLength": 1 },
    "answer": { "enum": ["Yes", "No", "N/A"] },
    "route": { "enum": ["verify", "apply", "resolve-blockers"] },
    "ownerPhase": { "enum": ["design", "test-design", "tasks", "apply", "review", "review-security", "verify", "archive"] },
    "findingKind": { "enum": ["none", "blocker", "warning"] },
    "compactRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["guidelineId", "category", "designApplies", "lifecycleStatus", "complies", "evidenceLocation", "finding"],
      "properties": {
        "guidelineId": { "type": "string", "pattern": "^SEC-[A-Z]+-[0-9]{3}$" },
        "category": { "type": "string", "minLength": 1 },
        "designApplies": { "$ref": "#/$defs/answer" },
        "lifecycleStatus": { "type": "string", "minLength": 1 },
        "complies": { "$ref": "#/$defs/answer" },
        "evidenceLocation": { "$ref": "#/$defs/ref" },
        "observations": { "type": "string" },
        "finding": { "$ref": "#/$defs/findingKind" }
      }
    },
    "sectionCoverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["corporateSection", "expected", "validated", "blockers", "warnings", "naCount", "notes"],
      "properties": {
        "corporateSection": { "type": "string", "minLength": 1 },
        "expected": { "type": "integer", "minimum": 0 },
        "validated": { "type": "integer", "minimum": 0 },
        "blockers": { "type": "integer", "minimum": 0 },
        "warnings": { "type": "integer", "minimum": 0 },
        "naCount": { "type": "integer", "minimum": 0 },
        "notes": { "type": "string" }
      }
    },
    "sourceRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sourceId", "corporateSection", "pciAlignment", "guidelineRefs", "compactMappings", "applies", "complies", "lifecycleStatus", "evidenceType", "evidenceLocation", "finding", "ownerPhase", "route"],
      "properties": {
        "sourceId": { "type": "string", "minLength": 1 },
        "corporateSection": { "type": "string", "minLength": 1 },
        "pciAlignment": { "type": "string", "minLength": 1 },
        "guidelineRefs": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/ref" } },
        "compactMappings": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^SEC-[A-Z]+-[0-9]{3}$" } },
        "applies": { "$ref": "#/$defs/answer" },
        "complies": { "$ref": "#/$defs/answer" },
        "lifecycleStatus": { "type": "string", "minLength": 1 },
        "evidenceType": { "enum": ["implementation-reference", "static-inspection", "test-evidence", "approved-exception", "n/a-evidence"] },
        "evidenceLocation": { "$ref": "#/$defs/ref" },
        "finding": { "$ref": "#/$defs/findingKind" },
        "ownerPhase": { "$ref": "#/$defs/ownerPhase" },
        "route": { "$ref": "#/$defs/route" }
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "severity", "summary", "evidenceLocation", "ownerPhase", "route"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "severity": { "enum": ["CRITICAL", "WARNING", "SUGGESTION"] },
        "summary": { "type": "string", "minLength": 1 },
        "evidenceLocation": { "$ref": "#/$defs/ref" },
        "ownerPhase": { "$ref": "#/$defs/ownerPhase" },
        "route": { "$ref": "#/$defs/route" }
      }
    },
    "exception": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "guidelineId", "approver", "approvedAt", "acceptedRiskRationale", "mitigationOrFollowUp", "evidenceGap"],
      "properties": {
        "status": { "const": "exception-approved" },
        "guidelineId": { "type": "string", "minLength": 1 },
        "approver": { "type": "string", "minLength": 1 },
        "approvedAt": { "type": "string", "minLength": 1 },
        "acceptedRiskRationale": { "type": "string", "minLength": 1 },
        "mitigationOrFollowUp": { "type": "string", "minLength": 1 },
        "evidenceGap": { "type": "string", "minLength": 1 }
      }
    },
    "stateArtifactRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref", "authority", "readable"],
      "properties": {
        "ref": { "$ref": "#/$defs/ref" },
        "authority": { "enum": ["canonical", "derived"] },
        "readable": { "type": "boolean" }
      }
    }
  }
}
