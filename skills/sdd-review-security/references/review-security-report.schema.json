{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gentle-ai.local/sdd-review-security/review-security-report.schema.json",
  "schemaName": "sdd-review-security.review-security-report.schema",
  "schemaVersion": 3,
  "title": "SDD Security Review Report JSON Contract",
  "description": "Canonical source-row-first per-change review-security-report.json contract. Derived Markdown is generated from this JSON and never owns validation.",
  "$comment": "rows[] is the only active security matrix. Catalog fields (corporateSection, pciAlignment, guidelineText, controlDomain, repoProfiles, runtimeSurface, dataSurface, appliesWhen) are joined from the catalog at render time and must not be repeated in this artifact.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaName","schemaVersion","changeName","artifactKind","generatedAt",
    "status","verdict","nextRecommended","totals","catalogRef",
    "catalogSnapshotId","unavailableTooling","generalReviewRef",
    "rows","exceptions","artifactMetadata"
  ],
  "properties": {
    "schemaName":        { "const": "sdd-review-security.review-security-report" },
    "schemaVersion":     { "type": "integer", "minimum": 3 },
    "changeName":        { "type": "string", "minLength": 1 },
    "artifactKind":      { "const": "canonical-security-review-report" },
    "generatedAt":       { "type": "string", "format": "date-time" },
    "status":            { "enum": ["success","blocked","partial"] },
    "verdict":           { "enum": ["PASS","PASS WITH WARNINGS","FAIL"] },
    "nextRecommended":   { "enum": ["verify","apply","resolve-blockers"] },
    "catalogRef":        { "const": "skills/sdd-review-security/references/security-guideline-catalog.operational.json" },
    "catalogSnapshotId": { "type": "string", "minLength": 1 },
    "unavailableTooling":{ "type": "array", "items": { "type": "string" } },
    "generalReviewRef":  { "type": "string", "minLength": 1 },
    "totals": {
      "type": "object", "additionalProperties": false,
      "required": ["sourceRowCount","validated","passing","failing","notApplicable","blockers","warnings","exceptions"],
      "properties": {
        "sourceRowCount": { "type": "integer", "const": 155 },
        "validated":      { "type": "integer", "minimum": 0 },
        "passing":        { "type": "integer", "minimum": 0 },
        "failing":        { "type": "integer", "minimum": 0 },
        "notApplicable":  { "type": "integer", "minimum": 0 },
        "blockers":       { "type": "integer", "minimum": 0 },
        "warnings":       { "type": "integer", "minimum": 0 },
        "exceptions":     { "type": "integer", "minimum": 0 }
      }
    },
    "rows": {
      "type": "array", "minItems": 155, "maxItems": 155,
      "items": { "$ref": "#/$defs/sourceRow" }
    },
    "exceptions": {
      "type": "array",
      "items": { "$ref": "#/$defs/exception" }
    },
    "artifactMetadata": {
      "type": "object", "additionalProperties": false,
      "required": ["canonicalJsonRef","derivedMarkdownRef","jsonPersisted","jsonReadBack","markdownGenerated","markdownPersisted","markdownReadBack","parityStatus","stateRegistration"],
      "properties": {
        "canonicalJsonRef":   { "$ref": "#/$defs/ref" },
        "derivedMarkdownRef": { "$ref": "#/$defs/ref" },
        "jsonPersisted":      { "type": "boolean" },
        "jsonReadBack":       { "type": "boolean" },
        "markdownGenerated":  { "type": "boolean" },
        "markdownPersisted":  { "type": "boolean" },
        "markdownReadBack":   { "type": "boolean" },
        "parityStatus":       { "enum": ["passed","stale","parity-failed","not-applicable"] },
        "stateRegistration":  { "type": "array", "minItems": 2, "items": { "$ref": "#/$defs/stateArtifactRef" } }
      }
    }
  },
  "$defs": {
    "ref":          { "type": "string", "minLength": 1 },
    "answer":       { "enum": ["Yes","No","N/A"] },
    "route":        { "enum": ["verify","apply","resolve-blockers"] },
    "ownerPhase":   { "enum": ["design","test-design","tasks","apply","review","review-security","verify","archive"] },
    "findingKind":  { "enum": ["none","blocker","warning"] },
    "evidenceType": { "enum": ["implementation-reference","static-inspection","test-evidence","approved-exception","n/a-evidence"] },
    "sourceRow": {
      "type": "object", "additionalProperties": false,
      "required": ["sourceId","applies","complies","lifecycleStatus","evidenceType","evidenceLocation","justification","finding","ownerPhase","route"],
      "properties": {
        "sourceId":        { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" },
        "applies":         { "$ref": "#/$defs/answer" },
        "complies":        { "$ref": "#/$defs/answer" },
        "lifecycleStatus": { "enum": ["not-started","planned","implemented","verified","not-applicable","exception-approved","blocked"] },
        "evidenceType":    { "$ref": "#/$defs/evidenceType" },
        "evidenceLocation":{ "$ref": "#/$defs/ref" },
        "justification":   { "type": "string", "minLength": 1 },
        "finding":         { "$ref": "#/$defs/findingKind" },
        "ownerPhase":      { "$ref": "#/$defs/ownerPhase" },
        "route":           { "$ref": "#/$defs/route" }
      }
    },
    "exception": {
      "type": "object", "additionalProperties": false,
      "required": ["sourceId","approver","approvedAt","acceptedRiskRationale","mitigationOrFollowUp","evidenceGap"],
      "properties": {
        "sourceId":               { "type": "string", "pattern": "^[0-9]+\\.[0-9]+$" },
        "approver":               { "type": "string", "minLength": 1 },
        "approvedAt":             { "type": "string", "minLength": 1 },
        "acceptedRiskRationale":  { "type": "string", "minLength": 1 },
        "mitigationOrFollowUp":   { "type": "string", "minLength": 1 },
        "evidenceGap":            { "type": "string", "minLength": 1 }
      }
    },
    "stateArtifactRef": {
      "type": "object", "additionalProperties": false,
      "required": ["ref","authority","readable"],
      "properties": {
        "ref":       { "$ref": "#/$defs/ref" },
        "authority": { "enum": ["canonical","derived"] },
        "readable":  { "type": "boolean" }
      }
    }
  }
}
