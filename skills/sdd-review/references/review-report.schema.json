{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gentle-ai.local/sdd-review/review-report.schema.json",
  "schemaName": "sdd-review.review-report.schema",
  "schemaVersion": 2,
  "title": "SDD Review Report JSON Contract",
  "description": "Canonical per-change review-report.json contract. review-report.md is a derived compatibility presentation generated from this JSON.",
  "$comment": "Evidence fields may cite paths, section anchors, sanitized summaries, and unavailable-tooling statements only. They must not include secrets, credentials, tokens, connection strings, PAN, PII, raw logs, sensitive payloads, production identifiers, generated bytes, or final-document-only values.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaName",
    "schemaVersion",
    "changeName",
    "artifactKind",
    "generatedAt",
    "status",
    "verdict",
    "nextRecommended",
    "totals",
    "catalogRef",
    "catalogSnapshotId",
    "unavailableTooling",
    "matrix",
    "artifactMetadata"
  ],
  "properties": {
    "schemaName": { "type": "string", "const": "sdd-review.review-report" },
    "schemaVersion": { "type": "integer", "minimum": 2 },
    "changeName": { "type": "string", "minLength": 1 },
    "artifactKind": { "type": "string", "const": "canonical-review-report" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "status": { "type": "string", "enum": ["success", "blocked", "partial"] },
    "verdict": { "type": "string", "enum": ["PASS", "PASS WITH WARNINGS", "FAIL"] },
    "nextRecommended": { "type": "string", "enum": ["review-security", "apply", "resolve-blockers"] },
    "catalogRef": { "type": "string", "const": "skills/sdd-review/references/review-control-catalog.json" },
    "catalogSnapshotId": { "type": "string", "minLength": 1 },
    "unavailableTooling": {
      "type": "array",
      "items": { "type": "string" }
    },
    "totals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["controlCount", "passing", "failing", "notApplicable", "blocking", "nonBlocking"],
      "properties": {
        "controlCount": { "type": "integer", "const": 96 },
        "passing": { "type": "integer", "minimum": 0 },
        "failing": { "type": "integer", "minimum": 0 },
        "notApplicable": { "type": "integer", "minimum": 0 },
        "blocking": { "type": "integer", "minimum": 0 },
        "nonBlocking": { "type": "integer", "minimum": 0 }
      }
    },
    "matrix": {
      "type": "array",
      "minItems": 96,
      "maxItems": 96,
      "items": { "$ref": "#/$defs/matrixRow" }
    },
    "artifactMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonicalJsonRef",
        "derivedMarkdownRef",
        "jsonPersisted",
        "jsonReadBack",
        "markdownGenerated",
        "markdownPersisted",
        "markdownReadBack",
        "parityStatus",
        "stateRegistration"
      ],
      "properties": {
        "canonicalJsonRef": { "$ref": "#/$defs/ref" },
        "derivedMarkdownRef": { "$ref": "#/$defs/ref" },
        "jsonPersisted": { "type": "boolean" },
        "jsonReadBack": { "type": "boolean" },
        "markdownGenerated": { "type": "boolean" },
        "markdownPersisted": { "type": "boolean" },
        "markdownReadBack": { "type": "boolean" },
        "parityStatus": { "type": "string", "enum": ["passed", "stale", "parity-failed", "not-applicable"] },
        "stateRegistration": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/stateArtifactRef" }
        }
      }
    }
  },
  "$defs": {
    "ref": { "type": "string", "minLength": 1 },
    "stateArtifactRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ref", "authority", "readable"],
      "properties": {
        "ref": { "$ref": "#/$defs/ref" },
        "authority": { "type": "string", "enum": ["canonical", "derived"] },
        "readable": { "type": "boolean" }
      }
    },
    "matrixRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item", "sourceItem", "complies", "findingType", "evidenceLocation"],
      "properties": {
        "item": { "type": "string", "pattern": "^REV-CORP-(00[1-9]|0[1-8][0-9]|09[0-6])$" },
        "sourceItem": { "type": "integer", "minimum": 1, "maximum": 96 },
        "complies": { "type": "string", "enum": ["Yes", "No", "N/A"] },
        "findingType": { "type": "string", "enum": ["blocking", "non-blocking", "none", "not-applicable"] },
        "finding": { "type": "string" },
        "evidenceLocation": { "$ref": "#/$defs/ref" },
        "notes": { "type": "string" }
      }
    }
  }
}
