{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gentle-ai.local/sdd-review/review-report.schema.json",
  "schemaName": "sdd-review.review-report.schema",
  "schemaVersion": 1,
  "title": "SDD Review Report JSON Contract",
  "description": "Canonical per-change review-report.json contract. review-report.md is a derived compatibility presentation generated from this JSON.",
  "$comment": "Evidence fields may cite paths, section anchors, sanitized summaries, and unavailable-tooling statements only. They must not include secrets, credentials, tokens, connection strings, PAN, PII, raw logs, sensitive payloads, production IDs/production identifiers, generated bytes, or final-document-only values. This schema does not define Excel, Python, script, or workbook generation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaName",
    "schemaVersion",
    "changeName",
    "artifactKind",
    "generatedAt",
    "sourceCatalogRef",
    "sourceCatalogSnapshotId",
    "derivedMarkdownRef",
    "verdict",
    "blockingFailureCount",
    "nonBlockingFindingCount",
    "nextRecommended",
    "inputsInspected",
    "runtimeChecks",
    "blockingSummary",
    "evidenceSummary",
    "operationalEvidenceSummary",
    "changedFileSecurityHandoff",
    "reviewMatrix",
    "validation",
    "presentation"
  ],
  "properties": {
    "schemaName": { "const": "sdd-review.review-report" },
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "changeName": { "type": "string", "minLength": 1 },
    "artifactKind": { "const": "canonical-review-report" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "sourceCatalogRef": { "const": "skills/sdd-review/references/review-control-catalog.json" },
    "sourceCatalogSnapshotId": { "type": "string", "minLength": 1 },
    "derivedMarkdownRef": {
      "type": "string",
      "description": "Backend-appropriate derived Markdown compatibility reference. OpenSpec uses openspec/changes/{change-name}/review-report.md, Engram/hybrid may use sdd/{change-name}/review, and none/ephemeral mode may use an inline marker.",
      "pattern": "^(openspec/changes/[^/]+/review-report\\.md|sdd/[^/]+/review|inline:(review-report\\.md|derived-markdown)|none:inline-review)$"
    },
    "verdict": { "enum": ["PASS", "PASS WITH WARNINGS", "FAIL"] },
    "blockingFailureCount": { "type": "integer", "minimum": 0 },
    "nonBlockingFindingCount": { "type": "integer", "minimum": 0 },
    "nextRecommended": { "enum": ["review-security", "apply", "resolve-blockers"] },
    "inputsInspected": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/inputRef" }
    },
    "runtimeChecks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["testRunner", "build", "coverage", "linter", "typeChecker", "formatter", "commandsExecuted", "unavailableToolingNote"],
      "properties": {
        "testRunner": { "$ref": "#/$defs/toolAvailability" },
        "build": { "$ref": "#/$defs/toolAvailability" },
        "coverage": { "$ref": "#/$defs/toolAvailability" },
        "linter": { "$ref": "#/$defs/toolAvailability" },
        "typeChecker": { "$ref": "#/$defs/toolAvailability" },
        "formatter": { "$ref": "#/$defs/toolAvailability" },
        "commandsExecuted": { "type": "array", "items": { "type": "string" } },
        "unavailableToolingNote": { "type": "string", "minLength": 1 }
      }
    },
    "blockingSummary": { "type": "array", "items": { "$ref": "#/$defs/blockingSummaryRow" } },
    "evidenceSummary": { "$ref": "#/$defs/namedSummary" },
    "operationalEvidenceSummary": { "$ref": "#/$defs/namedSummary" },
    "changedFileSecurityHandoff": { "$ref": "#/$defs/namedSummary" },
    "reviewMatrix": {
      "type": "array",
      "minItems": 96,
      "maxItems": 96,
      "items": { "$ref": "#/$defs/reviewMatrixRow" }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "catalogControlCount",
        "expectedControlCount",
        "uniqueItemIds",
        "completeItemIdSequence",
        "completeSourceItemSequence",
        "allowedCompliesVocabulary",
        "naRowsHaveEvidenceAndRationale",
        "blockingCountsMatchVerdict",
        "derivedMarkdownGenerated",
        "derivedMarkdownReadBack",
        "derivedMarkdownParity",
        "safeEvidenceChecked"
      ],
      "properties": {
        "catalogControlCount": { "type": "integer", "const": 96 },
        "expectedControlCount": { "type": "integer", "const": 96 },
        "uniqueItemIds": { "type": "boolean" },
        "completeItemIdSequence": { "type": "boolean" },
        "completeSourceItemSequence": { "type": "boolean" },
        "allowedCompliesVocabulary": { "type": "array", "items": { "enum": ["Yes", "No", "N/A"] }, "minItems": 3, "maxItems": 3, "uniqueItems": true },
        "naRowsHaveEvidenceAndRationale": { "type": "boolean" },
        "blockingCountsMatchVerdict": { "type": "boolean" },
        "derivedMarkdownGenerated": { "type": "boolean" },
        "derivedMarkdownReadBack": { "type": "boolean" },
        "derivedMarkdownParity": { "type": "boolean" },
        "safeEvidenceChecked": { "type": "boolean" }
      }
    },
    "presentation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["markdownTemplateRef", "derivedMarkdownRef", "matrixColumns", "categoryColumnRendered"],
      "properties": {
        "markdownTemplateRef": { "const": "skills/sdd-review/references/report-template.md" },
        "derivedMarkdownRef": {
          "type": "string",
          "description": "Must match the selected backend's derived Markdown compatibility reference; it is not limited to OpenSpec file paths.",
          "pattern": "^(openspec/changes/[^/]+/review-report\\.md|sdd/[^/]+/review|inline:(review-report\\.md|derived-markdown)|none:inline-review)$"
        },
        "matrixColumns": {
          "type": "array",
          "prefixItems": [
            { "const": "Item" },
            { "const": "Artifact/Deliverable" },
            { "const": "Requirement" },
            { "const": "Reviewer" },
            { "const": "Standard" },
            { "const": "Severity" },
            { "const": "Complies" },
            { "const": "Affected Requirement" },
            { "const": "Evidence Location" },
            { "const": "Observations/Comments" }
          ],
          "minItems": 10,
          "maxItems": 10
        },
        "categoryColumnRendered": { "const": false }
      }
    }
  },
  "$defs": {
    "inputRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact", "ref", "readable"],
      "properties": {
        "artifact": { "type": "string", "minLength": 1 },
        "ref": { "type": "string", "minLength": 1 },
        "readable": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    },
    "toolAvailability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["available", "command", "evidence"],
      "properties": {
        "available": { "type": "boolean" },
        "command": { "type": "string" },
        "evidence": { "type": "string", "minLength": 1 }
      }
    },
    "blockingSummaryRow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item", "severity", "affectedRequirement", "evidenceLocation", "requiredFollowUp"],
      "properties": {
        "item": { "type": "string" },
        "severity": { "type": "string" },
        "affectedRequirement": { "type": "string" },
        "evidenceLocation": { "type": "string" },
        "requiredFollowUp": { "type": "string" }
      }
    },
    "namedSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "items"],
      "properties": {
        "summary": { "type": "string" },
        "items": { "type": "array", "items": { "type": "string" } }
      }
    },
    "reviewMatrixRow": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "item",
        "sourceItem",
        "artifactDeliverable",
        "requirement",
        "reviewer",
        "standard",
        "severity",
        "complies",
        "affectedRequirement",
        "evidenceLocation",
        "observationsComments"
      ],
      "properties": {
        "item": { "type": "string", "pattern": "^REV-CORP-(00[1-9]|0[1-8][0-9]|09[0-6])$" },
        "sourceItem": { "type": "integer", "minimum": 1, "maximum": 96 },
        "category": { "type": "string" },
        "artifactDeliverable": { "type": "string", "minLength": 1 },
        "requirement": { "type": "string", "minLength": 1 },
        "reviewer": { "const": "sdd-review" },
        "standard": { "type": "string", "minLength": 1 },
        "severity": { "type": "string", "minLength": 1 },
        "complies": { "enum": ["Yes", "No", "N/A"] },
        "affectedRequirement": { "type": "string" },
        "evidenceLocation": { "type": "string" },
        "observationsComments": { "type": "string" },
        "findingType": { "enum": ["blocking", "non-blocking", "none", "not-applicable"] }
      }
    }
  }
}
